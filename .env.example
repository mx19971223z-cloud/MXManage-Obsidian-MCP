#
# MXManage-Obsidian-MCP Server 环境配置模板
#
# 使用方式：
#   1. 复制为 .env
#   2. 按实际值替换占位符
#   3. .env 不要提交到版本库（已在 .gitignore 中忽略）
#

# Obsidian 仓库对应的 Git 仓库地址
# 支持 Gitee、GitHub、GitLab、与自建 Git 服务
VAULT_REPO=https://gitee.com/yourusername/your-obsidian-repo.git

# 使用分支（通常为 main 或 master）
VAULT_BRANCH=main

# Git 访问令牌
# 仓库平台会从 URL 自动识别：
#   - GitHub: Personal Access Token（repo 权限）
#   - GitLab: Personal Access Token（api 权限）
#   - Gitee: 私人令牌（Personal Access Token）
#   - 自建 Git: 访问令牌或密码（同时需要 GIT_USERNAME）
GIT_TOKEN=your_token_here

# Git 用户名（仅自建/通用 Git 提供商需要，Gitee配置私人令牌后可省略这一步）
# GitHub、GitLab 通常可留空
# GIT_USERNAME=your_username

# 本地 Vault 克隆目录（可选）
# 原生默认：./vault-local
# Docker 默认：/app/vaults/vault-local
# LOCAL_VAULT_PATH=/custom/path/to/vault

# 日记路径模板（支持 {{date}}）
JOURNAL_PATH_TEMPLATE=Journal/{{date}}.md

# {{date}} 的格式
JOURNAL_DATE_FORMAT=YYYY-MM-DD

# 自动活动日志追加到的标题
JOURNAL_ACTIVITY_SECTION="## Activity"

# 创建新日日记时使用的模板文件
JOURNAL_FILE_TEMPLATE=Templates/Daily Note.md

# OAuth 客户端配置（HTTP 模式必填）
OAUTH_CLIENT_ID=obsidian-mcp-client
OAUTH_CLIENT_SECRET=replace_me_with_secret

# OAuth 登录页中输入的个人认证令牌
PERSONAL_AUTH_TOKEN=replace_me_with_personal_token

# 服务对外访问地址（部署后请改成公网地址）
BASE_URL=http://localhost:3000

# 会话有效期（毫秒），默认 24 小时
SESSION_EXPIRY_MS=86400000
