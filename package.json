{
  "name": "obsidian-mcp",
  "version": "0.1",
  "private": true,
  "type": "module",
  "description": "MCP server for git-backed Obsidian vaults",
  "keywords": [
    "obsidian",
    "mcp",
    "oauth",
    "docker"
  ],
  "author": "MXManage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mx19971223z-cloud/MXManage-Obsidian-MCP.git"
  },
  "homepage": "https://github.com/mx19971223z-cloud/MXManage-Obsidian-MCP#readme",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build --workspace @obsidian-mcp/app",
    "build:app": "npm run build --workspace @obsidian-mcp/app",
    "clean": "rm -rf dist && npm run clean --workspace @obsidian-mcp/app --if-present",
    "dev": "npm run dev --workspace @obsidian-mcp/app",
    "dev:http": "npm run dev:http --workspace @obsidian-mcp/app",
    "lint": "eslint \"packages/**/*.{ts,tsx}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript-eslint": "^8.15.0",
    "typescript": "^5.7.3"
  }
}
